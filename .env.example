# Copy this file to .env and fill in real values from:
# Supabase Dashboard -> Project Settings -> Database -> Connection string

# Pooled connection (PgBouncer, transaction mode, port 6543) - used at runtime by Prisma Client.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) - used by Prisma Migrate / db pull.
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Auth (Dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"

# Anthropic API (server-only — never expose with a NEXT_PUBLIC_ prefix)
ANTHROPIC_API_KEY="[ANTHROPIC-API-KEY]"

# Footer contact links (server-only, no NEXT_PUBLIC_ prefix needed)
CONTACT_EMAIL="you@example.com"
GITHUB_URL="https://github.com/[org]/[repo]"
